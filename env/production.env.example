COMPOSE_PROJECT_NAME=via

TZ=UTC

VIA_IMAGE_REGISTRY=local
VIA_IMAGE_TAG=latest

VIA_LISTEN_ADDR=:9090
VIA_GATEWAY_PORT=9090

VIA_NATS_URL=nats://via-nats:4222
VIA_NATS_CLIENT_PORT=4222
VIA_NATS_MONITOR_PORT=8222

USER_SERVICE_IMAGE=ghcr.io/your-org/via-user-service:latest
USER_SERVICE_PORT=8081

FLEET_SERVICE_IMAGE=ghcr.io/your-org/via-fleet-service:latest
FLEET_SERVICE_PORT=8082

NOTIFICATION_WORKER_IMAGE=ghcr.io/your-org/via-notification-worker:latest
NOTIFICATION_LOG_LEVEL=info

# ── Cache ────────────────────────────────────────────────────────
CACHE_MAX_ITEMS=10000
CACHE_DEFAULT_TTL=5m
CACHE_CLEANUP_INTERVAL=1m

# ── Distributed Tracing (OpenTelemetry OTLP) ────────────────────
TRACING_ENABLED=false
TRACING_ENDPOINT=localhost:4318
TRACING_INSECURE=true
TRACING_SAMPLE_RATE=0.1

# ── Sentry (Error & Performance Monitoring) ──────────────────────
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_DEBUG=false

# ── Auth / RBAC ─────────────────────────────────────────────────
AUTH_ENABLED=false
# Format: key:role:fleet_id,key2:role2:fleet_id2
AUTH_API_KEYS=

# ── General ─────────────────────────────────────────────────────
VIA_ENVIRONMENT=production
VIA_RELEASE=
